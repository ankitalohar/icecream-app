# API and persistence
PORT=3001
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/vivelle?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-jwt-secret

# Optional admin provisioned on API startup.
ADMIN_NAME=Vivelle Operations
ADMIN_EMAIL=admin@your-domain.example
ADMIN_PHONE=9876543210
ADMIN_ADDRESS=Admin office
ADMIN_PASSWORD=change-this-admin-password

# Optional Firestore mirror. Use Application Default Credentials in production,
# or provide a service account JSON string for local API development.
FIREBASE_PROJECT_ID=icecream-app-5e7ee
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_USE_APPLICATION_DEFAULT=true

# Browser Firebase Auth configuration for the custom-token session established
# after API login/signup.
VITE_FIREBASE_API_KEY=replace-with-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=icecream-app-5e7ee.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=icecream-app-5e7ee
VITE_FIREBASE_APP_ID=replace-with-firebase-web-app-id
