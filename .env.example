# API and persistence
PORT=3001
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/vivelle?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-jwt-secret
OTP_SECRET=replace-with-a-different-long-random-otp-secret

# For local development only: prints and returns the OTP instead of delivering it.
OTP_DEV_MODE=true

# Production email OTP delivery (Nodemailer SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASS=replace-with-smtp-password
OTP_EMAIL_FROM=Vivelle <login@your-domain.example>

# Production SMS OTP delivery (Twilio)
TWILIO_ACCOUNT_SID=AC_replace_with_account_sid
TWILIO_AUTH_TOKEN=replace-with-auth-token
TWILIO_FROM_PHONE=+15551234567

# An admin is provisioned on API startup. Admin login is OTP-only.
ADMIN_NAME=Vivelle Operations
ADMIN_EMAIL=admin@your-domain.example
ADMIN_PHONE=+15551234567
